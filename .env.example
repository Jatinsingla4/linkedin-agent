# ── Required ────────────────────────────────────────────────
# Gemini (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key

# LinkedIn developer app (linkedin.com/developers)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# Run: python -m entrypoints.get_linkedin_token  (token expires every 60 days)
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=your_linkedin_person_urn

# Telegram (@BotFather + @userinfobot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Unsplash (unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# ── Optional (defaults shown) ───────────────────────────────
GEMINI_MODEL=gemini-2.5-flash
POSTS_PER_WEEK=4
APPROVAL_TIMEOUT_HOURS=12
GENERATE_VERSIONS=2
ENABLE_FIRST_COMMENT=true
DRY_RUN=false

# Day-of-week routing (0=Mon … 6=Sun)
PERSONAL_STORY_DAY=3
POLL_DAY=6
CAROUSEL_DAY=5

# Writing persona
YOUR_NAME=Jatin
YOUR_ROLE=Digital Marketing & Brand Strategist
YOUR_COMPANY=Grapes Worldwide
YOUR_LINKEDIN_NICHE=marketing,branding,AI,FMCG,agency life,startup
